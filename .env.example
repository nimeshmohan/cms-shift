# Copy this file to .env and fill in your values

# Optional: PostgreSQL connection string
# If not set, the app will use in-memory storage (data lost on restart)
# DATABASE_URL=postgresql://user:password@localhost:5432/html_converter

# Server port (default: 5000)
PORT=5000

# Webflow API token (required for Webflow CMS import features)
# WEBFLOW_API_TOKEN=your_webflow_api_token_here
